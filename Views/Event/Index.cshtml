@model IEnumerable<vps.Models.Event.Event>

@{ViewData["Title"] = "Botanical Events";}

<div class="py-5 mb-4 rounded-3" style="background-color: #1B4332;">
    <div class="container-fluid py-2 px-4">
        <h1 class="display-6 fw-bold text-white">
            <i class="bi bi-tree-fill me-2" style="color: #52B788;"></i>Botanical Events
        </h1>
        <p class="lead mb-0" style="color: #A8D5BA;">
            Explore and manage all upcoming nature and garden events.
        </p>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold" style="color: #1B4332;">All Events</h4>
    <a class="btn fw-semibold text-white"
       style="background-color: #2D6A4F;"
       asp-action="Create" asp-controller="Event">
        <i class="bi bi-plus-circle me-1"></i> New Event
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5" style="color: #6B4226;">
        <i class="bi bi-flower3 display-1" style="color: #52B788;"></i>
        <p class="mt-3 fs-5">No events yet. Plant the first one!</p>
        <a asp-action="Create" asp-controller="Event"
           class="btn fw-semibold text-white mt-2" style="background-color: #2D6A4F;">
            <i class="bi bi-plus-circle me-1"></i> Create Event
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var ev in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm"
                     style="border-left: 4px solid #2D6A4F !important;">
                    @if (!string.IsNullOrEmpty(ev.Img))
                    {
                        <img src="@ev.Img" class="card-img-top object-fit-cover" style="height: 180px;"
                             alt="@ev.Title" onerror="this.style.display='none'">
                    }
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0" style="color: #1B4332;">@ev.Title</h5>
                            @{
                                var badgeClass = ev.Status == vps.Models.Event.Status.Active
                                    ? "bg-success"
                                    : ev.Status == vps.Models.Event.Status.Inactive
                                        ? "bg-secondary" : "bg-danger";
                            }
                            <span class="badge @badgeClass ms-2">@ev.Status</span>
                        </div>
                        <p class="card-text small mb-2">
                            <i class="bi bi-geo-alt-fill me-1" style="color: #6B4226;"></i>
                            <span class="text-muted">@ev.Location</span>
                        </p>
                        <p class="card-text small" style="color: #4A4A4A;">
                            @(ev.Description.Length > 100 ? ev.Description[..100] + "…" : ev.Description)
                        </p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2 justify-content-end"
                         style="border-color: #D4E8D4 !important;">
                        <a class="btn btn-sm fw-semibold text-white"
                           style="background-color: #C9A84C;"
                           asp-route-id="@ev.Id" asp-action="Edit" asp-controller="Event">
                            <i class="bi bi-pencil-fill me-1"></i>Edit
                        </a>
                        <form asp-action="Delete" asp-controller="Event" asp-route-id="@ev.Id"
                              method="post"
                              onsubmit="return confirm('Remove this event from the garden?');">
                            <button type="submit" class="btn btn-sm btn-danger fw-semibold">
                                <i class="bi bi-trash3-fill me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
